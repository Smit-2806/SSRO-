# ==============================================================================
# SSRO Project - Environment Configurations Template
# Rename this file to '.env' and fill in your keys.
# ==============================================================================

# 1. NASA FIRMS Map Key
# Get your free key instantly at: https://firms.modaps.eosdis.nasa.gov/api/status/
FIRMS_MAP_KEY=your_nasa_firms_map_key_here

# 2. Copernicus Climate Data Store (CDS) API
# Get your credentials at: https://cds.climate.copernicus.eu/
# Format is: <UID>:<API-KEY>
CDSAPI_URL=https://cds.climate.copernicus.eu/api/v2
CDSAPI_KEY=your_cds_uid:your_cds_api_key_here
